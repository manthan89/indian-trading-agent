{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "python",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "uvicorn backend.app:app --host 0.0.0.0 --port $PORT",
    "port": 8000
  }
}